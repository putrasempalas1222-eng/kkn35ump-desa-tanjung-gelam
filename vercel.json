{
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/auth/:path*",
      "destination": "/api/auth/:path*"
    },
    {
      "source": "/admin/:path*",
      "destination": "/api/admin/:path*"
    },
    {
      "source": "/division-chat/:path*",
      "destination": "/api/division-chat/:path*"
    },
    {
      "source": "/api-proxy/:path*",
      "destination": "/api/api-proxy/:path*"
    },
    {
      "source": "/putra-ai-proxy/:path*",
      "destination": "/api/putra-ai-proxy/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
